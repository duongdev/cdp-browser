{
  "name": "cdp-browser",
  "version": "2.0.0",
  "productName": "CDP Browser",
  "description": "A lightweight browser that connects to remote Chromium via Chrome DevTools Protocol",
  "author": "duongdev",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"sleep 2 && electron .\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "preview": "electron .",
    "dist": "vite build && electron-builder --mac",
    "dist:dir": "vite build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "dev.duong.cdp-browser",
    "productName": "CDP Browser",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "!node_modules/**/*",
      "node_modules/ws/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "radix-ui": "^1.4.3",
    "ws": "*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "electron": "*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.1"
  }
}
