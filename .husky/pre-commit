[ "$CI" = "true" ] && exit 0

# Never commit directly on main. docs/ + CLAUDE.md are shared across worktrees
# (.claude/scripts/e2e-link-worktree.sh symlinks, conductor-sync.sh rsyncs), so a doc
# write meant for a feature branch lands wherever HEAD happens to be. Committed on
# main it forks main from the branch, and the branch merge later arrives as a duplicate.
# Override: ALLOW_MAIN_COMMIT=1 git commit ...  (release tooling, hotfix)
if [ "$(git rev-parse --abbrev-ref HEAD)" = "main" ] && [ "${ALLOW_MAIN_COMMIT:-}" != "1" ]; then
  echo "refusing to commit on main — branch first: git switch -c <type>/<name>" >&2
  echo "(override: ALLOW_MAIN_COMMIT=1 git commit ...)" >&2
  exit 1
fi

pnpm exec lint-staged
